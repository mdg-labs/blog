---
/**
 * Copy to: src/pages/de/blog/[slug].astro (website, slugbase — bilingual sites only)
 *
 * German post detail: only generates paths for locale "de".
 */
import { getCollection, render } from "astro:content";
import {
  blogMdxComponents,
  filterByLocale,
  filterPublished,
  resolvePostSlug,
} from "@mdg-labs/blog";
import BlogPostLayout from "@mdg-labs/blog/layouts/BlogPostLayout.astro";

export const prerender = true;

export async function getStaticPaths() {
  const posts = filterByLocale(
    filterPublished(await getCollection("blog")),
    "de",
  );
  return posts.map((entry) => ({
    params: { slug: resolvePostSlug(entry) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
---

<BlogPostLayout post={entry.data} headings={headings}>
  <Content components={blogMdxComponents} />
</BlogPostLayout>
